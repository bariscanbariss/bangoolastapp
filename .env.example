# ============================================================
#  Bangoo Mobile App — Environment Variables Template
#  Copy this file: cp .env.example .env.local
#  Then fill in your actual values below.
# ============================================================

# Your Medusa backend URL
MEDUSA_BACKEND_URL=https://your-medusa-backend.com

# Your Medusa publishable API key (from Medusa Admin > Settings > API Keys)
PUBLISHABLE_API_KEY=pk_your_publishable_key_here

# Default locale (e.g. tr-TR, en-US)
DEFAULT_LOCALE=tr-TR

# Next.js on-demand revalidation secret
REVALIDATE_SECRET=your-revalidation-secret-here
